{
  "extends": "./tsconfig.web.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "types": ["node", "jest", "electron-vite/node"]
  },
  "include": [
    "src/main/tests/**/*.ts",
    "src/photonics-dmx/tests/**/*.ts",
    "src/photonics-dmx/**/*.test.ts",
    "src/services/**/tests/**/*.ts",
    "src/renderer/src/**/*.test.ts"
  ],
  "exclude": ["node_modules", "out", "dist", "coverage"]
}
