    {
      "id": "motion-vogue",
      "name": "Vogue",
      "description": "On each beat, every light moves to its own random stage bearing over 800ms (set-position).",
      "variables": [
        {
          "name": "vogueLights",
          "type": "light-array",
          "scope": "cue",
          "initialValue": []
        },
        {
          "name": "vogueCurrentLight",
          "type": "light-array",
          "scope": "cue",
          "initialValue": []
        },
        {
