      "nodes": {
        "events": [
          {
            "id": "vogue-event-beat",
            "type": "event",
            "eventType": "beat"
          }
        ],
        "actions": [
          {
            "id": "vogue-action-pos",
            "type": "action",
            "effectType": "set-position",
            "target": {
              "groups": {
                "source": "variable",
                "name": "vogueCurrentLight"
              },
              "filter": {
                "source": "literal",
                "value": "all"
              }
            },
            "position": {
              "mode": "direction",
              "bearing": {
                "source": "variable",
                "name": "vogueBearing"
              },
              "angle": {
                "source": "literal",
                "value": 20
              }
            },
            "timing": {
              "waitForCondition": {
                "source": "literal",
                "value": "none"
              },
              "waitForTime": {
                "source": "literal",
                "value": 0
              },
              "duration": {
                "source": "literal",
                "value": 800
              },
              "waitUntilCondition": {
                "source": "literal",
                "value": "beat"
              },
              "waitUntilTime": {
                "source": "literal",
                "value": 0
              },
              "easing": {
                "source": "literal",
                "value": "easeInOut"
              },
              "level": {
                "source": "literal",
                "value": 1
              }
            },
            "layer": {
              "source": "literal",
              "value": 120
            }
          }
        ],
        "logic": [
          {
            "id": "vogue-logic-all-lights",
            "type": "logic",
            "logicType": "config-data",
            "dataProperty": "all-lights-array",
            "assignTo": "vogueLights"
          },
          {
            "id": "vogue-logic-foreach",
            "type": "logic",
            "logicType": "for-each-light",
            "sourceVariable": "vogueLights",
            "currentLightVariable": "vogueCurrentLight",
            "currentIndexVariable": "vogueCurrentIndex"
          },
          {
            "id": "vogue-logic-random-bearing",
            "type": "logic",
            "logicType": "random",
            "mode": "random-choice",
            "choices": [
              "downstage",
              "stage-right",
              "stage-left",
              "upstage",
              "se",
              "ne",
              "sw",
              "nw"
            ],
            "assignTo": "vogueBearing"
          }
        ],
        "eventRaisers": [],
        "eventListeners": [],
        "effectRaisers": [],
        "notes": []
      },
      "connections": [
        {
          "from": "vogue-event-beat",
