      "parameters": [],
      "variables": [
        {
          "name": "group",
          "type": "string",
          "scope": "cue",
          "initialValue": "front,back",
          "description": "Target light groups (comma-separated)",
          "isParameter": true
        },
        {
          "name": "filter",
          "type": "string",
          "scope": "cue",
          "initialValue": "all",
          "description": "Light pattern filter",
          "isParameter": true
        },
        {
          "name": "layer",
          "type": "number",
          "scope": "cue",
          "initialValue": 0,
          "description": "DMX layer",
          "isParameter": true
        },
        {
          "name": "color",
          "type": "color",
          "scope": "cue",
          "initialValue": "white",
          "description": "Flash colour",
          "isParameter": true
        },
        {
          "name": "brightness",
          "type": "string",
          "scope": "cue",
