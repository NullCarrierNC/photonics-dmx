            },
            "timing": {
              "waitForCondition": {
                "source": "literal",
                "value": "none"
              },
              "waitForTime": {
                "source": "literal",
                "value": 0
              },
              "duration": {
                "source": "variable",
                "name": "fadeInMs"
              },
              "waitUntilCondition": {
                "source": "literal",
                "value": "delay"
              },
              "waitUntilTime": {
                "source": "variable",
                "name": "holdMs"
              },
              "easing": { "source": "literal", "value": "linear" },
              "level": {
                "source": "literal",
                "value": 1
              }
            },
            "layer": {
              "source": "variable",
              "name": "layer"
            }
