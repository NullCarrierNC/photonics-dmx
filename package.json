{
  "name": "photonics-dmx",
  "version": "0.0.24-alpha.2-interim-15",
  "description": "A DMX sequencer for YARG and RB3E",
  "main": "./out/main/index.js",
  "author": "Null Carrier",
  "homepage": "https://photonics.rocks",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "cross-env NODE_OPTIONS=--trace-warnings electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder install-app-deps && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "c8 --reporter=lcov --reporter=text npm test",
    "test:color-blending": "npx ts-node src/photonics-dmx/tests/runColorBlendingTest.ts",
    "test:color-analysis": "npx ts-node src/photonics-dmx/tests/runColorAnalysis.ts"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@electron-toolkit/preload": "3.0.1",
    "@electron-toolkit/utils": "3.0.0",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "chokidar": "3.6.0",
    "codemirror": "^6.0.2",
    "date-fns": "4.1.0",
    "dmx-ts": "0.4.0",
    "electron-updater": "^6.3.9",
    "enttec-open-dmx-usb": "^4.0.1",
    "jotai": "2.10.1",
    "react-icons": "5.3.0",
    "react-resizable-panels": "^4.7.0",
    "reactflow": "11.11.1",
    "sacn": "4.6.1",
    "uuid": "11.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "1.0.1",
    "@jest/globals": "^30.0.0",
    "@jest/test-sequencer": "^30.2.0",
    "@types/jest": "29.5.14",
    "@types/node": "20.14.8",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "babel-plugin-istanbul": "^5.2.0",
    "bytenode": "1.5.6",
    "c8": "^10.1.3",
    "cross-env": "7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "electron-vite": "3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "postcss-loader": "8.1.1",
    "prettier": "3.3.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "3.4.14",
    "terser": "5.37.0",
    "ts-jest": "^29.4.6",
    "typescript": "5.5.2",
    "vite": "^5.4.19"
  },
  "overrides": {
    "esbuild": "0.25.12"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": "eslint --fix",
    "*.{ts,tsx,js,cjs,mjs,json}": "prettier --write"
  }
}
